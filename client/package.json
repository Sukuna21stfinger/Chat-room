{
  "name": "chatapp-client",
  "version": "1.0.0",
  "description": "ChatApp Desktop Client",
  "main": "public/electron.js",
  "homepage": "./",
  "dependencies": {
    "axios": "^1.13.6",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "fs-extra": "^11.3.4",
    "path": "^0.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "socket.io-client": "^4.8.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "npm run build && electron-builder --publish=never"
  },
  "build": {
    "productName": "ChatApp",
    "appId": "com.chatapp.desktop",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "public/**/*",
      "main.js",
      "public/electron.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "wait-on": "^8.0.5"
  }
}
