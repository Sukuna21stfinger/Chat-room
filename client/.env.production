# Production Server URLs - Update these after deploying to Vercel\nREACT_APP_API_URL=https://your-server-name.vercel.app/api\nREACT_APP_SERVER_URL=https://your-server-name.vercel.app\n\n# For local development, uncomment these:\n# REACT_APP_API_URL=http://localhost:5000/api\n# REACT_APP_SERVER_URL=http://localhost:5000